<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- v0.1 permission baseline.
         See docs/v_model/architecture_options.md § Permission Baseline.
         The list is the source of truth. Any new permission requires an
         ADR (see AGENTS.md § Documentation discipline). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- v1.0 / Phase C PR 2 / ADR-021: coarse location for
         geofence triggers (TriggerLocationEnter/Exit).
         ACCESS_FINE_LOCATION stays out of scope per the v0.1
         carve-out (see docs/v_model/architecture_options.md §
         Permission Baseline). The user's location is never
         stored or transmitted — geofences are matched in
         Dart on the local position stream. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- v1.0 / Phase E PR 1 / ADR-023: read calendar for
         TriggerCalendarEvent (event-start / event-end /
         reminder / busy). Used by CalendarService to watch
         the user's calendar via CalendarContract. We never
         WRITE to the calendar; we only read event metadata
         (id, title, calendar id, time) to drive routine
         matches. No event bodies or attendees are stored or
         transmitted off-device. -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />

    <!-- v1.0 / Phase F PR 1 / ADR-019: call-screening for
         the Japan silent-mode routine (SYS-075). The
         CallScreeningService is bound by the system with
         the signature-protected BIND_SCREENING_SERVICE
         permission (declared on the <service> element, not
         here). No new user-facing runtime permission is
         required; READ_PHONE_STATE stays out of scope per
         the privacy policy and the v0.2f deferral. -->
    <!-- (no <uses-permission> for call screening — see <service>
         below for the BIND_SCREENING_SERVICE attribute.) -->

    <!-- v1.1g / ADR-030 / SYS-086: PACKAGE_USAGE_STATS is a
         special-access permission for the planned
         TriggerForegroundApp (v1.2 — "do X when I open app
         Y"). Android does not show a runtime prompt for it;
         the user toggles it on in Settings → Special access
         → Usage access. The rationale UX (deep-link +
         re-probe on resume) lives in
         lib/widgets/permission_sheet.dart and
         lib/services/usage_stats_service.dart. The
         `tools:ignore="ProtectedPermissions"` marker
         suppresses the manifest-merger lint because the
         permission is opt-in only (the user is never
         blocked from using do it for declining). -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- v1.3c / Phase 14 / SYS-113 / ADR-043:
         USE_FULL_SCREEN_INTENT is a special-access
         permission for strong-mode habit full-screen
         mission launches. On Android 14+ the OS
         suppresses full-screen intents from background-
         launched apps that do not hold this permission,
         so the user sees a notification instead of the
         full-screen mission screen — defeating the
         strong-mode interruption contract (SYS-113). The
         Kotlin probe (`NotificationManager
         .canUseFullScreenIntent()`) + the deep-link
         (`Settings
         .ACTION_MANAGE_APP_USE_FULL_SCREEN_INTENT`,
         API 34+; falls back to `ACTION_APPLICATION_SETTINGS`
         on API 32/33) live in
         `FullScreenIntentChannel.kt`. The `tools:ignore`
         marker mirrors the v1.1g PACKAGE_USAGE_STATS
         precedent: the permission is opt-in only (declining
         does NOT block any feature — the notification still
         fires; the user just has to tap it). -->
    <uses-permission
        android:name="android.permission.USE_FULL_SCREEN_INTENT"
        tools:ignore="ProtectedPermissions" />

    <application
        android:label="@string/app_name"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- v1.3d / Phase 15 / SYS-114 / ADR-044: the
             full-screen mission activity. Strong-mode
             habit alarms fire this activity via the
             `doit/full_screen` MethodChannel's
             `showHabitMission` / `showRoutineOverlay`
             handlers (FullScreenIntentChannel.kt) and
             strong-mode notifications call it via
             `setFullScreenIntent`. The activity is a
             thin `FlutterActivity` shell that hosts a
             `/mission` Flutter route; the
             `MissionLauncherScreen` /
             `RoutineOverlayScreen` widgets parse the
             route and render the right surface.

             Why a separate activity (vs a new launchMode
             on MainActivity): distinct task affinity
             keeps the strong-mode launch out of the
             MainActivity back-stack; distinct theme +
             launchMode + keyguard-bypass flags match
             the strong-mode interruption contract
             (SYS-114) without polluting MainActivity's
             cold-launch config; `excludeFromRecents`
             hides the launch from the app-switcher so a
             missed launch is not a phantom entry.

             Keyguard bypass (`showOnLockScreen`,
             `turnScreenOn`, `showWhenLocked`) +
             `FLAG_DISMISS_KEYGUARD` (set in
             `onCreate`) implement the strong-mode
             contract: the OS surfaces this activity
             on top of any lockscreen.

             `exported="false"`: only our own code
             (FullScreenIntentChannel) launches this
             activity. No external Intent filter. The
             system can still start it from a
             PendingIntent built by our own code. -->
        <activity
            android:name=".FullScreenActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:theme="@style/LaunchTheme"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:showWhenLocked="true"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize" />

        <!-- Boot survival (SYS-016). Receives BOOT_COMPLETED,
             LOCKED_BOOT_COMPLETED, MY_PACKAGE_REPLACED, and
             TIMEZONE_CHANGED. Re-arms every pending alarm.
             See docs/v_model/notification_reliability.md § Layer 3. -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- Alarm receiver. Fires when AlarmManager triggers a
             pending reminder. The Dart side handles the actual
             notification + next-occurrence scheduling.
             See docs/v_model/notification_reliability.md § Layer 1. -->
        <receiver
            android:name=".AlarmReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.doit.FIRE_ALARM" />
            </intent-filter>
        </receiver>

        <!-- v1.4a / Phase 28 / SYS-115 / ADR-045 / WF-042:
             the Android home-screen widget. The OS calls
             `DoitWidgetProvider.onUpdate` on every bound
             widget id when the APPWIDGET_UPDATE broadcast
             fires (initial bind, the 30-min periodic floor,
             and after `WidgetUpdater.refreshAll` posts
             the `ACTION_REFRESH_WIDGET` custom action).
             The provider is `exported="false"` (Android 12+
             requires an explicit declaration; only the
             launcher binds this provider via the
             `APPWIDGET_PICK` activity). No new
             <uses-permission> is required for widget
             rendering. -->
        <receiver
            android:name=".DoitWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/doit_widget_info" />
        </receiver>

        <!-- v1.0 / Phase F PR 1 / ADR-019 / SYS-075: the
             call-screening service for the Japan silent-mode
             routine. The OS invokes onScreenCall(Call.Details)
             for every incoming call before the dialer rings;
             we return a CallResponse (allow / silence /
             disconnect) and (when the contact matches the
             configured list) override the ringer to
             RINGER_MODE_NORMAL. The bound permission is the
             signature-protected BIND_SCREENING_SERVICE,
             granted automatically by the system at install
             time. No READ_PHONE_STATE — see ADR-019. -->
        <service
            android:name=".CallInterceptor"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- v0.4b-release-fix-2 (ADR-013 follow-up): disable
             workmanager's `androidx.startup` auto-init.

             The `androidx.startup.InitializationProvider` is
             declared transitively by the workmanager plugin via
             the `androidx.startup` library. On a fresh process
             start the provider's `onCreate` instantiates every
             `androidx.startup.Initializer` it knows about,
             including `androidx.work.WorkManagerInitializer`,
             which calls `WorkManager.getInstance(context)`.
             That call constructs the workmanager `WorkDatabase`
             (a Room-generated SQLite database). On release
             builds the Room-generated `WorkDatabase_Impl` class
             was being stripped or renamed by R8 even though
             `isMinifyEnabled = false` was the intent — AGP
             defaults are version-dependent and the build was
             running R8, leaving the `Class.forName(...)` lookup
             in `WorkManagerInitializer.create` to throw
             "Failed to create an instance of class
             androidx.work.impl.WorkDatabase.canonicalName". The
             crash fires before `MainActivity.onCreate` so no
             Dart code can catch it.

             Removing the `WorkManagerInitializer` meta-data
             from the merged manifest defers the WorkManager
             singleton creation to the first Dart-side call to
             `Workmanager().initialize(...)` (which lives in
             `lib/services/backup_scheduler.dart`'s
             `BackupScheduler.init`). The singleton is built
             lazily from that point on; the workmanager
             periodic task is registered later, from the
             settings screen, when the user opts in. See
             `docs/v_model/decision_record.md` ADR-013. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- v1.0 / Phase F PR 1 / ADR-019: query the dialer
             for the ANSWER intent. The CallInterceptor's
             restorePriorRinger() path launches the dialer's
             answer screen so the user can pick up a ringing
             call once the ringer has been snapped back to
             NORMAL. Android 11+ package-visibility requires
             us to declare the intent we resolve against. -->
        <intent>
            <action android:name="android.intent.action.ANSWER" />
        </intent>
    </queries>
</manifest>
