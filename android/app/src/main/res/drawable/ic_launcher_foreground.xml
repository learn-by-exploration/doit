<?xml version="1.0" encoding="utf-8"?>
<!--
  v1.1i / ADR-032 / SYS-088: launcher foreground glyph.

  Lowercase sans-serif 'd' + small filled "check dot", white
  on transparent. Android applies the launcher mask (circle,
  squircle, teardrop) at draw time; the white glyph is all
  the user sees.

  Layout (108dp adaptive-icon canvas, 66dp safe zone centered):
    Stem:        x ∈ [23, 29], y ∈ [24, 84]   (6dp × 60dp)
    Outer bowl:  center (54, 54), R = 25      (the 'd' bowl)
    Inner bowl:  center (54, 54), R = 16      (the counter)
    Check dot:   center (80, 80), R = 4       (bottom-right)

  Path data uses evenOdd fill so the inner circle carves the
  counter out of the outer disk and the stem-bowl tangent
  region does not double-count.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#FFFFFFFF"
        android:fillType="evenOdd"
        android:pathData="
            M 23,24 L 29,24 L 29,84 L 23,84 Z
            M 54,54 m -25,0 a 25,25 0 1,0 50,0 a 25,25 0 1,0 -50,0 Z
            M 54,54 m -16,0 a 16,16 0 1,1 32,0 a 16,16 0 1,1 -32,0 Z
            M 80,80 m -4,0  a 4,4   0 1,0 8,0  a 4,4   0 1,0 -8,0  Z
        " />
</vector>