<?xml version="1.0" encoding="utf-8"?>
<!--
  v1.1i / ADR-032 / SYS-088: themed-icon monochrome layer.

  Android 13+ themed icons recolor this layer against the
  user's wallpaper-derived tint, so we ship pure white. Same
  glyph as `ic_launcher_foreground.xml` (the 'd' + check
  dot), but the themed-icon system reads fillColor and tints
  the whole shape uniformly.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#FFFFFFFF"
        android:fillType="evenOdd"
        android:pathData="
            M 23,24 L 29,24 L 29,84 L 23,84 Z
            M 54,54 m -25,0 a 25,25 0 1,0 50,0 a 25,25 0 1,0 -50,0 Z
            M 54,54 m -16,0 a 16,16 0 1,1 32,0 a 16,16 0 1,1 -32,0 Z
            M 80,80 m -4,0  a 4,4   0 1,0 8,0  a 4,4   0 1,0 -8,0  Z
        " />
</vector>