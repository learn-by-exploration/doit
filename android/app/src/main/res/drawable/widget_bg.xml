<?xml version="1.0" encoding="utf-8"?>
<!-- v1.4a / Phase 28 / SYS-115 / ADR-045 / WF-042.

     Background drawable for the home widget. A rounded
     rectangle with a 1dp outline using the theme's
     ?android:attr/colorOutline attribute so the widget
     respects light / dark themes. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="12dp" />
    <solid android:color="?android:attr/colorBackground" />
    <stroke
        android:width="1dp"
        android:color="?android:attr/colorOutline" />
</shape>