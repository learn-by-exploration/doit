<?xml version="1.0" encoding="utf-8"?>
<!--
  v1.1i / ADR-032 / SYS-088: adaptive-icon entry point.

  On API 26+ the launcher resolves `@mipmap/ic_launcher` to
  this file (per `AndroidManifest.xml:66`'s
  `android:icon="@mipmap/ic_launcher"` reference). The OS
  applies the launcher's mask (circle / squircle / teardrop)
  to the background + foreground composite at draw time.

  Background  = solid brand purple (see `ic_launcher_background.xml`).
  Foreground  = white 'd' + check dot glyph (see `ic_launcher_foreground.xml`).
  Monochrome  = same 'd' + check dot glyph as the foreground,
                recolored against the user's wallpaper-derived
                tint on Android 13+ themed icons (see
                `ic_launcher_monochrome.xml`).

  Pre-API-26 devices fall back to the legacy
  `mipmap-{mdpi,hdpi,xhdpi,xxhdpi,xxxhdpi}/ic_launcher.png`
  files (the Flutter default 5 PNGs). Those PNGs are not
  deleted by this PR — the v1.2 follow-up can regenerate
  them from the master vector if the launcher visuals on a
  pre-26 device need to be on-brand.

  Reference: https://developer.android.com/develop/ui/views/launch/icon-element-design
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
    <monochrome android:drawable="@drawable/ic_launcher_monochrome" />
</adaptive-icon>