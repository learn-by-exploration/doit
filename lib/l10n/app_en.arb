{
  "@@locale": "en",

  "appTitle": "do it",
  "@appTitle": {
    "description": "The app display name shown in the launcher and About section."
  },

  "homeAppBarTitle": "do it",
  "@homeAppBarTitle": {
    "description": "Home screen AppBar title. Mirrors the app name for the non-selection mode."
  },
  "homeSelectionAppBarTitle": "{count, plural, =0{No selection} =1{1 selected} other{{count} selected}}",
  "@homeSelectionAppBarTitle": {
    "description": "Home screen AppBar title when the user has entered selection mode.",
    "placeholders": {
      "count": {
        "type": "int",
        "format": "compact"
      }
    }
  },
  "homeSnackbarMarkedDone": "Marked done.",
  "homeSnackbarMarkedCount": "Marked {count} do(s) done.",
  "@homeSnackbarMarkedCount": {
    "description": "Snackbar copy after a bulk-mark operation.",
    "placeholders": {
      "count": {
        "type": "int",
        "format": "compact"
      }
    }
  },
  "homeTileMarkDone": "Mark done",
  "@homeTileMarkDone": {
    "description": "Tooltip / aria-label for the in-app home tile's 'Mark done' IconButton. Mirrors the widget surface (v1.4a)."
  },
  "homeTileStreakLabel": "day streak",
  "@homeTileStreakLabel": {
    "description": "Subtitle rendered next to the streak number on the in-app home tile (e.g. '5 day streak'). Mirrors the widget's middle row."
  },
  "homeTileAlreadyDoneTooltip": "Already done for today",
  "@homeTileAlreadyDoneTooltip": {
    "description": "Tooltip shown when the user long-presses a 'Done' tile that has already been marked done today."
  },
  "homeTileStrongModeHint": "Opens the mission chain",
  "@homeTileStrongModeHint": {
    "description": "Tooltip shown for the tile's 'Mark done' IconButton on a Strong-mode do. The tap launches the mission UI (v1.3d / SYS-114) which writes the completion on ChainPassed."
  },
  "homeTileSkipToday": "Skip today",
  "@homeTileSkipToday": {
    "description": "Tooltip / aria-label for the in-app home tile's 'Skip today' IconButton (v1.4c / SYS-117). Tap writes a rest-day completion (consumes one budget unit) so the streak is credited and the day is marked intentionally off."
  },
  "homeTileSkipAlready": "Rest day taken",
  "@homeTileSkipAlready": {
    "description": "Tooltip shown when the user long-presses a tile that has already been marked as a rest day for today. Mirrors the 'Already done for today' hint for the manual-completion surface."
  },
  "homeTileSkipSuccess": "Rest day taken — streak holds.",
  "@homeTileSkipSuccess": {
    "description": "Snackbar copy after a successful 'Skip today' tap (v1.4c / SYS-117)."
  },
  "homeTileSkipBudgetExhausted": "No rest days left this month.",
  "@homeTileSkipBudgetExhausted": {
    "description": "Snackbar copy when the user taps 'Skip today' but the do has zero rest-day budget remaining for the current month (v1.4c / SYS-117)."
  },
  "homeTileBudgetRemaining": "{remaining}/{limit} rest days left",
  "@homeTileBudgetRemaining": {
    "description": "Caption under the streak badge on the home tile (v1.4c / SYS-117). Renders only when restDaysPerMonth > 0 and at least one rest day has been used. placeholders: remaining (int) and limit (int).",
    "placeholders": {
      "remaining": {
        "type": "int"
      },
      "limit": {
        "type": "int"
      }
    }
  },
  "homeTileBudgetNoRemaining": "No rest days left",
  "@homeTileBudgetNoRemaining": {
    "description": "Caption under the streak badge on the home tile when restDaysPerMonth > 0 but the user has used all budget units for the month (v1.4c / SYS-117). Distinct from 'No budget configured' — the do opted into rest days but has used them all."
  },
  "homeTileUndoToday": "Undo today",
  "@homeTileUndoToday": {
    "description": "Tooltip / aria-label for the in-app home tile's 'Undo today' IconButton (v1.4d / SYS-118). Visible only when the tile is 'resolved' for today (Done tap or Skip tap recorded). Tap opens a confirm dialog; the confirm reverts the completion via CompletionLogService.deleteById."
  },
  "homeTileUndoConfirm": "Undo today's completion?",
  "@homeTileUndoConfirm": {
    "description": "Title of the AlertDialog that confirms an in-app home tile Undo tap (v1.4d / SYS-118). Mirrors the CompletionLogSection's 'Delete this completion?' title but at the tile surface."
  },
  "homeTileUndoConfirmBody": "This will remove today's check-in. The streak will update.",
  "@homeTileUndoConfirmBody": {
    "description": "Body copy of the AlertDialog that confirms an in-app home tile Undo tap (v1.4d / SYS-118). Sets the user's expectation: the row is deleted, the streak decrements by 1 (or the rest-day budget re-increments by 1 for the skip path)."
  },
  "homeTileUndoSuccess": "Completion removed.",
  "@homeTileUndoSuccess": {
    "description": "Snackbar copy after a successful in-app home tile Undo tap (v1.4d / SYS-118). Mirrors the CompletionLogSection's 'Completion removed.' snackbar but at the tile surface."
  },
  "homeTileUndoNotToday": "Nothing to undo for today.",
  "@homeTileUndoNotToday": {
    "description": "Snackbar copy when the in-app home tile Undo tap completes but the DB has no row to delete (v1.4d / SYS-118). Defensive — the dialog is gated on _isResolvedToday == true, but the DB is the source of truth and a concurrent app-tile rebuild could leave a dangling flag."
  },
  "homeTileSparklineSemantics": "Last 7 days",
  "@homeTileSparklineSemantics": {
    "description": "Semantics label for the 7-day streak history sparkline row on the in-app home tile (v1.4e / SYS-119). Wraps the 7 dots in a single Semantics node so screen readers announce 'Last 7 days' once instead of 7 separate dots."
  },
  "widgetSkipToday": "Skip today",
  "@widgetSkipToday": {
    "description": "Tooltip / contentDescription for the Android home widget's 'Skip today' ImageButton (v1.4f / SYS-120). Tapping it appends a rest-day completion via CompletionLogService (consuming one rest-day budget unit) so the streak is credited and the day is marked intentionally off. Mirrors the in-app tile's `homeTileSkipToday`."
  },
  "widgetUndoToday": "Undo today",
  "@widgetUndoToday": {
    "description": "Tooltip / contentDescription for the Android home widget's 'Undo today' ImageButton (v1.4f / SYS-120). Tapping it deletes today's completion (or rest-day) row via CompletionLogService.deleteById. Visible only when isCompletedToday is true; mirrors the in-app tile's `homeTileUndoToday`."
  },
  "homeEmptyTitle": "No dos yet.",
  "homeRetryButton": "Retry",
  "homeTileEdit": "Edit",
  "@homeTileEdit": {
    "description": "Tooltip for the in-app home tile's per-tile edit IconButton (v1.4h / SYS-122). Tapping opens the AddHabitScreen in edit mode for this do — same destination as the body-tap but explicit so the affordance is discoverable without long-press."
  },
  "homeTileDelete": "Delete",
  "@homeTileDelete": {
    "description": "Tooltip for the in-app home tile's per-tile delete IconButton (v1.4h / SYS-122). Tapping opens a confirm dialog; on confirm, the do is removed from the DB and the tile disappears. The post-delete SnackBar offers an Undo action that re-saves the captured do."
  },
  "homeTileDeleteConfirm": "Delete \"{doName}\"?",
  "@homeTileDeleteConfirm": {
    "description": "Title of the AlertDialog that confirms a per-tile delete tap (v1.4h / SYS-122). Includes the do name so the user can verify they're deleting the right entry — destructive actions should always confirm. The {doName} placeholder is the do's display name.",
    "placeholders": {
      "doName": {
        "type": "String"
      }
    }
  },
  "homeTileDeleteConfirmBody": "This will remove the do and all of its completions. You can undo for a few seconds after.",
  "@homeTileDeleteConfirmBody": {
    "description": "Body copy of the AlertDialog that confirms a per-tile delete tap (v1.4h / SYS-122). Sets the expectation: cascade-delete the completions too (the CompletionLogService.deleteByHabit foreign-key cascade handles this), and tells the user the SnackBar will offer an Undo affordance."
  },
  "homeSnackbarDoDeleted": "Deleted \"{doName}\".",
  "@homeSnackbarDoDeleted": {
    "description": "Snackbar copy after a successful per-tile delete tap (v1.4h / SYS-122). The {doName} placeholder is the captured do's name. The SnackBar has an Undo action that re-saves the captured do via DoRepository.save.",
    "placeholders": {
      "doName": {
        "type": "String"
      }
    }
  },
  "homeSnackbarDoDeletedUndo": "Undo",
  "@homeSnackbarDoDeletedUndo": {
    "description": "Action label for the per-tile delete SnackBar's Undo affordance (v1.4h / SYS-122). Tapping it re-saves the captured do via DoRepository.save, restoring the row + its streak history (the streak calculator re-derives from the surviving completions). Matches the standard Material 'Undo' pattern."
  },
  "homeSnackbarDoDeleteFailed": "Could not delete. Try again.",
  "@homeSnackbarDoDeleteFailed": {
    "description": "Snackbar copy when the per-tile delete helper returns false (DB locked, constraint violation, etc.) — the tile is NOT removed and the user can retry. Defensive: the home screen keeps its previous state so a partial delete doesn't leave the UI inconsistent."
  },
